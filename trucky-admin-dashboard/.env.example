# REST API base URL (include /api suffix)
VITE_API_URL=http://localhost:3000/api

# WebSocket host (no /api suffix, Socket.IO path is /ws)
VITE_WS_URL=http://localhost:3000

# Production example (replace with your EC2 public IP or domain):
# VITE_API_URL=http://YOUR_EC2_IP:3000/api
# VITE_WS_URL=http://YOUR_EC2_IP:3000
