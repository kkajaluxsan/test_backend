# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fleet_tracker

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# Firebase FCM
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# AWS S3 (Phase 2)
AWS_REGION=eu-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=trucky-italia-pod

# Twilio (Phase 2 - SOS only)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_ADMIN_NUMBER=

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:3001,https://dashboard.truckyitalia.com,http://13.53.205.211:5173

# Alert thresholds
OVERSPEED_THRESHOLD_KMH=110
IDLE_THRESHOLD_MINUTES=30
OFFLINE_THRESHOLD_MINUTES=5
